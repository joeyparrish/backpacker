<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- App header: gold icon + app name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:src="@drawable/ic_header_icon"
                android:layout_marginEnd="12dp"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textAppearance="?attr/textAppearanceHeadline3" />

        </LinearLayout>

        <!-- Collapsible "Setup" section header -->
        <LinearLayout
            android:id="@+id/setupHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/section_setup"
                android:textAppearance="?attr/textAppearanceHeadline5" />

            <ImageView
                android:id="@+id/ivSetupChevron"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_expand_more_24"
                android:contentDescription="@null" />

        </LinearLayout>

        <!-- Collapsible setup content -->
        <LinearLayout
            android:id="@+id/setupContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Step 1: Accessibility -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/tvAccessibilityStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/permission_accessibility_title"
                        android:textAppearance="?attr/textAppearanceSubtitle1" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/permission_accessibility_desc"
                        android:textAppearance="?attr/textAppearanceBody2"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOpenAccessibility"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/permission_accessibility_button" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Step 2: Notification permission -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/permission_notification_title"
                        android:textAppearance="?attr/textAppearanceSubtitle1" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/permission_notification_desc"
                        android:textAppearance="?attr/textAppearanceBody2"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRequestNotification"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/permission_notification_button" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Step 3: Battery optimization -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/permission_battery_title"
                        android:textAppearance="?attr/textAppearanceSubtitle1" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/permission_battery_desc"
                        android:textAppearance="?attr/textAppearanceBody2"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBattery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/permission_battery_button" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- "Automation" section heading -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_automation"
            android:textAppearance="?attr/textAppearanceHeadline5"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvLifetimeSpins"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textAppearance="?attr/textAppearanceBody1" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/overlay_label"
            app:thumbTint="@color/switch_thumb_tint"
            app:trackTint="@color/switch_track_tint" />

        <!-- Collapsible "Debug" section header -->
        <LinearLayout
            android:id="@+id/debugHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/section_debug"
                android:textAppearance="?attr/textAppearanceHeadline5" />

            <ImageView
                android:id="@+id/ivDebugChevron"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_expand_more_24"
                android:contentDescription="@null" />

        </LinearLayout>

        <!-- Collapsible debug content -->
        <LinearLayout
            android:id="@+id/debugContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchDebugScan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/debug_scan_label"
                app:thumbTint="@color/switch_thumb_tint"
                app:trackTint="@color/switch_track_tint" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchSpinnerDebug"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/spinner_debug_label"
                app:thumbTint="@color/switch_thumb_tint"
                app:trackTint="@color/switch_track_tint" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchSaveFailures"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/save_failures_label"
                app:thumbTint="@color/switch_thumb_tint"
                app:trackTint="@color/switch_track_tint" />

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:textAppearance="?attr/textAppearanceCaption"
                android:alpha="0.5"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
