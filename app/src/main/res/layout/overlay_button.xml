<?xml version="1.0" encoding="utf-8"?>
<!--
    Floating overlay button drawn by TapperService via WindowManager.
    Attached with TYPE_ACCESSIBILITY_OVERLAY so no SYSTEM_ALERT_WINDOW permission is needed.
    Draggable — touch listener is set up in OverlayView.kt.

    The FAB uses a black backgroundTint and the Pokéstop icon (no system tint override)
    so it visually mirrors the launcher icon: cyan Pokéstop on black.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabToggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/ic_fab_pokestop"
        app:tint="@null"
        app:backgroundTint="@color/black"
        app:maxImageSize="40dp"
        android:contentDescription="Toggle automation"
        android:alpha="0.85" />

</FrameLayout>
