<?xml version="1.0" encoding="utf-8"?>
<!--
    FAB icon: aerodynamic sports-car side profile (facing right), 24×24 dp viewport.

    Geometry (car faces RIGHT; rear is left, nose is right):
      • Body — asymmetric 9-point polygon
                rear bottom  (2,17)  → rear top     (2,14)   upright hatch/trunk
                             (2,14)  → C-pillar top (5,8)    steep rear window
                             (5,8)   → roof rear    (9,6)    transition to roof
                             (9,6)   → roof front   (14,6)   flat roofline
                             (14,6)  → A-pillar base(19,11)  forward-raked windshield (45°)
                             (19,11) → hood end     (21,11)  short flat hood
                             (21,11) → nose top     (23,14)  sloped front
                             (23,14) → nose bottom  (22,17)  wedge nose (slight undercut)
                             close Z back to (2,17)           flat underbody
      • Rear wheel — circle, centre (5,19),  r=2.5
      • Front wheel — circle, centre (18,19), r=2.5

    Fill is white so OverlayView.updateAppearance() can tint it to any
    colour via imageTintList without fighting the drawable's own hue.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Body: fastback sports-car silhouette, facing right -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 2,17 L 2,14 L 5,8 L 9,6 L 14,6 L 19,11 L 21,11 L 23,14 L 22,17 Z" />

    <!-- Rear wheel: centre (5,19), r=2.5 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M 7.5,19 A 2.5,2.5 0 0 1 5,21.5 A 2.5,2.5 0 0 1 2.5,19
                      A 2.5,2.5 0 0 1 5,16.5 A 2.5,2.5 0 0 1 7.5,19 Z" />

    <!-- Front wheel: centre (18,19), r=2.5 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M 20.5,19 A 2.5,2.5 0 0 1 18,21.5 A 2.5,2.5 0 0 1 15.5,19
                       A 2.5,2.5 0 0 1 18,16.5 A 2.5,2.5 0 0 1 20.5,19 Z" />

</vector>
