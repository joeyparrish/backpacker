<?xml version="1.0" encoding="utf-8"?>
<!--
    FAB icon: aerodynamic sports-car side profile (facing right), 24×24 dp viewport.
    Body uses Bézier curves for smooth, organic lines.

    Body path (car faces RIGHT; rear is left, nose is right):
      M 2,17 L 2,15       upright hatch/trunk
      C 2,9 5,9 9,8       C-pillar: sweeps from vertical into roofline
      L 14,8              flat roofline
      C 18,8 20,12 21,13  A-pillar: horizontal roof into raked windshield base
      L 22,13             short flat hood
      C 23,13 23,15 22,17 rounded nose (bulges forward, sweeps down to underbody)
      Z                   flat underbody back to (2,17)

    • Rear wheel  — circle, centre (5,19),  r=2.5
    • Front wheel — circle, centre (18,19), r=2.5

    Fill is white so OverlayView.updateAppearance() can tint it to any
    colour via imageTintList without fighting the drawable's own hue.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Body: fastback silhouette with Bézier curves, facing right -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M 2,17 L 2,15
            C 2,9 5,9 9,8
            L 14,8
            C 18,8 20,12 21,13
            L 22,13
            C 23,13 23,15 22,17
            Z" />

    <!-- Rear wheel: centre (5,19), r=2.5 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M 7.5,19 A 2.5,2.5 0 0 1 5,21.5 A 2.5,2.5 0 0 1 2.5,19
                      A 2.5,2.5 0 0 1 5,16.5 A 2.5,2.5 0 0 1 7.5,19 Z" />

    <!-- Front wheel: centre (18,19), r=2.5 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M 20.5,19 A 2.5,2.5 0 0 1 18,21.5 A 2.5,2.5 0 0 1 15.5,19
                       A 2.5,2.5 0 0 1 18,16.5 A 2.5,2.5 0 0 1 20.5,19 Z" />

</vector>
