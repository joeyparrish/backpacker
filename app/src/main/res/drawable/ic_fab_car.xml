<?xml version="1.0" encoding="utf-8"?>
<!--
    FAB icon: simple car side-profile silhouette, 24×24 dp viewport.

    Geometry:
      • Body+cabin — hexagon,  x=1–23,  y=9–20
                     (sloped front/rear pillars give the cabin taper)
      • Left wheel  — circle,  centre (6,20),  r=3,  bottom y=23
      • Right wheel — circle,  centre (18,20), r=3,  bottom y=23

    Fill is white so OverlayView.updateAppearance() can tint it to any
    colour via imageTintList without fighting the drawable's own hue.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Body + cabin (hexagonal side profile) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 1,20 L 1,14 L 5,9 L 19,9 L 23,14 L 23,20 Z" />

    <!-- Left wheel: centre (6,20), r=3 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M 9,20 A 3,3 0 0 1 6,23 A 3,3 0 0 1 3,20
                    A 3,3 0 0 1 6,17 A 3,3 0 0 1 9,20 Z" />

    <!-- Right wheel: centre (18,20), r=3 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M 21,20 A 3,3 0 0 1 18,23 A 3,3 0 0 1 15,20
                     A 3,3 0 0 1 18,17 A 3,3 0 0 1 21,20 Z" />

</vector>
