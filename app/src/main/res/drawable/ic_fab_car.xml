<?xml version="1.0" encoding="utf-8"?>
<!--
    FAB icon: sedan side-profile silhouette (facing right), 24×24 dp viewport.
    Based on a stock sedan outline icon. All curves are Bézier.

    Body path (car faces RIGHT; rear is left, nose is right):
      M 1,17 L 1,14         upright rear face (trunk/bumper)
      Q 2,13 3,12           rounded step at trunk-lid shoulder (C-pillar base)
      C 5,9 7,7 9,7         C-pillar sweeps up into roofline
      L 15,7                flat roofline
      C 18,7 20,11 21,12    A-pillar: horizontal roof → raked windshield base
      L 22,12               short flat hood
      Q 23,15 22,17         rounded front bumper
      Z                     flat underbody back to (1,17)

    • Rear wheel  — circle, centre (5,19),  r=2.5
    • Front wheel — circle, centre (18,19), r=2.5

    Fill is white so OverlayView.updateAppearance() can tint it to any
    colour via imageTintList without fighting the drawable's own hue.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Body: sedan silhouette with Bézier curves, facing right -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M 1,17 L 1,14
            Q 2,13 3,12
            C 5,9 7,7 9,7
            L 15,7
            C 18,7 20,11 21,12
            L 22,12
            Q 23,15 22,17
            Z" />

    <!-- Rear wheel: centre (5,19), r=2.5 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M 7.5,19 A 2.5,2.5 0 0 1 5,21.5 A 2.5,2.5 0 0 1 2.5,19
                      A 2.5,2.5 0 0 1 5,16.5 A 2.5,2.5 0 0 1 7.5,19 Z" />

    <!-- Front wheel: centre (18,19), r=2.5 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M 20.5,19 A 2.5,2.5 0 0 1 18,21.5 A 2.5,2.5 0 0 1 15.5,19
                       A 2.5,2.5 0 0 1 18,16.5 A 2.5,2.5 0 0 1 20.5,19 Z" />

</vector>
