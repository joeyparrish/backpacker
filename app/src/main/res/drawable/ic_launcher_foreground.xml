<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive-icon foreground layer.

    Viewport: 108×108 dp (required by the adaptive-icon safe-zone spec).
    Content:  pokestop_paths in 50×63 coordinate space, placed via a <group>
              translate so the disc centre lands at (54, 46) — the same
              position as the original hand-authored version.
              translateX=29  translateY=21  →  centre=(29+25, 21+25)=(54,46) ✓

    The path uses fillType="evenOdd" so Pokéball details are transparent
    cutouts rather than explicit dark fills.  The black launcher background
    (ic_launcher_background) shows through, reproducing the original look.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:translateX="29"
        android:translateY="21">
        <path
            android:fillType="evenOdd"
            android:fillColor="#17C8FF"
            android:pathData="@string/pokestop_paths" />
    </group>

</vector>
