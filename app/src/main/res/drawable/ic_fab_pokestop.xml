<?xml version="1.0" encoding="utf-8"?>
<!--
    FAB idle-state icon: Pokéstop silhouette at 24 dp.

    Viewport is square (63×63) so the drawable scales uniformly into the
    24×24 dp FAB icon slot.  The pokestop_paths content is 50 units wide in
    a 63-unit tall space, so a translateX of 6.5 centres it horizontally
    (6.5 + 50 + 6.5 = 63).

    fillColor is cyan for the IDLE state.  OverlayView sets imageTintList
    to null (idle/cyan) or Color.RED (running) at runtime; the evenOdd
    transparent cutouts remain transparent regardless of tint, so Pokéball
    details are preserved in all states.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="63"
    android:viewportHeight="63">

    <group android:translateX="6.5">
        <path
            android:fillType="evenOdd"
            android:fillColor="#17C8FF"
            android:pathData="@string/pokestop_paths" />
    </group>

</vector>
