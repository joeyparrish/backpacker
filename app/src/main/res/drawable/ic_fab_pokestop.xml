<?xml version="1.0" encoding="utf-8"?>
<!--
    Floating-action-button icon: Pokéstop silhouette scaled to 24 dp.

    Geometry (24×24 viewport), designed to fill the icon slot:

      • Outer ring (annulus)  centre (12,10)  outer r=10  inner r=8
      • Inner disc            centre (12,10)  r=6.5  (1.5 dp gap to ring)
      • Pole                  1.5 dp wide, y 16.5–22
      • Base platform         14 dp wide, y 22–23.5

    Content spans x=2–22 (83 % of viewport) and y=0–23.5 (98 % of viewport).
    All paths are cyan (#17C8FF); OverlayView tints the icon red when
    the FAB is in the RUNNING state.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Outer ring: annulus via even-odd fill (outer r=10, inner r=8, centre 12,10) -->
    <path
        android:fillType="evenOdd"
        android:fillColor="#17C8FF"
        android:pathData="
            M 22,10 A 10,10 0 0 1 12,20 A 10,10 0 0 1 2,10
                    A 10,10 0 0 1 12,0  A 10,10 0 0 1 22,10 Z
            M 20,10 A 8,8 0 0 1 12,18 A 8,8 0 0 1 4,10
                    A 8,8 0 0 1 12,2  A 8,8 0 0 1 20,10 Z" />

    <!-- Inner disc: r=6.5, centre (12,10) — 1.5 dp gap to ring inner edge -->
    <path
        android:fillColor="#17C8FF"
        android:pathData="
            M 18.5,10 A 6.5,6.5 0 0 1 12,16.5 A 6.5,6.5 0 0 1 5.5,10
                      A 6.5,6.5 0 0 1 12,3.5  A 6.5,6.5 0 0 1 18.5,10 Z" />

    <!-- Pole: 1.5 dp wide, connects disc bottom to base -->
    <path
        android:fillColor="#17C8FF"
        android:pathData="M 11.25,16.5 L 12.75,16.5 L 12.75,22 L 11.25,22 Z" />

    <!-- Base platform: 14 dp wide, 1.5 dp tall -->
    <path
        android:fillColor="#17C8FF"
        android:pathData="M 5,22 L 19,22 L 19,23.5 L 5,23.5 Z" />

</vector>
