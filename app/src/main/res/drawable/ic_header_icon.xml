<?xml version="1.0" encoding="utf-8"?>
<!--
    App header icon: Pokéstop in gold, used in MainActivity's title row.

    Viewport matches the pokestop_paths coordinate space exactly (50×63),
    so no <group> transform is needed.  The path's evenOdd fill renders
    Pokéball details as transparent cutouts; the gold fill is applied via
    android:fillColor rather than a runtime tint so it works without any
    code.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="50dp"
    android:height="63dp"
    android:viewportWidth="50"
    android:viewportHeight="63">

    <path
        android:fillType="evenOdd"
        android:fillColor="@color/gold"
        android:pathData="@string/pokestop_paths" />

</vector>
